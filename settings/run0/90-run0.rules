/* run0 polkit rules for single-user desktop
 *
 * - Members of the wheel group authenticate with their own credentials
 * - AUTH_ADMIN_KEEP enables 5-minute password/auth caching
 * - After authenticating once, subsequent run0 calls
 *   within the timeout do not require re-authentication
 */
polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        subject.isInGroup("wheel")) {
        return polkit.Result.AUTH_ADMIN_KEEP;
    }
});
